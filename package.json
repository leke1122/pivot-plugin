{
  "name": "feishu-bitable-pivot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "飞书多维表格透视表插件：读取当前数据表并做 Excel 风格透视分析",
  "output": "dist",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc -b && vite build && node scripts/prepare-dist.mjs",
    "build:web": "tsc -b && vite build",
    "upload": "npm run build && opdev upload ./dist -t block -v patch -d \"透视表插件\"",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^1.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
